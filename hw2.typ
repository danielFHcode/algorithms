+ #diagram($
	1 edge("d",->, bend: #{-10deg}) edge("d",<-,bend: #10deg) edge("dr",->,bend:#10deg) edge("dr",<-,bend: #(-10deg)) \
	2 edge(->, bend: #10deg) edge(<-, bend: #(-10deg), ) & 3
  $)
  
  זהו מעגל קשיר שכאשר מריצים עליו DFS החל מ-$1$ מקבלים קשת חוצה מ-$3$ ל-$2$ או מ-$2$ ל-$3$ (תלוי בסדר האיברים ברשימת שכנויות).

  קיימת דוגמא נגדית לכן הטענה לא נכונה

+ נריץ DFS מ-$u$, אז $f[u] > f[v] >= d[v] >= d[u] = 0$, לכן אנו ניגשים לצומת $v$ אחרי שהתחלנו לעבור על הצאצאים של $u$ ולפני שסיימנו, לכן $v$ בהכרח צאצא של $u$. אז הטענה נכונה.

#pagebreak()
#pagebreak()
#set page(margin: (y: 3.4cm))

+ נניח בשלילה כי $G$ לא עץ, ידוע כי ל-$G$ קיים עץ DFS לכן הוא קשיר מה שאומר שקיים ב-$G$ מעגל פשוט $v_1 - v_2 - ... - v_n - v_1$, נריץ DFS ו-BFS מ-$v_1$ ונקבל כי בעץ ה-BFS $v_2$ ו-$v_n$ שניהם ילדים של $v_1$, ובעץ ה-BFS $v_2$ ילד של $v_1$ אך $v_n$ לא או להיפך (תלוי בסדר רשימת השכנויות) ולכן $T != T$ שזו סתירה ולכן $G$ עץ. הגדרה שקולה לעץ (כשמדובר בגרף לא קשיר) היא שיש מסלול יחיד בין כל שני קדקודים ולכן BFS ו-DFS שניהם יצרו את $G$ עצמו כי הם בהכרח כללו את כל המסלולים. אז הטענה נכונה

// + #diagram($
//     & 1 edge(->, "dl") edge(->,"d") edge(->, "dr") \
//     2 edge(->) & 3 edge("d", ->) edge(->) & 4 edge(->,"d") \
//     & 5 & 6 edge(->, "l")
//   $)
  
//   הדרך היחידה לקבל עץ בהרצת DFS או BFS היא להתחיל מ-$1$ כיוון שאחרת יהיה יותר מרכיב קשירות אחד.

//   בהרצת DFS מ-$1$ העץ המתקבל יכיל את אחד מהמסלולים הבאים בהסתמך על סדר רשימת השכנויות:
//   - $1 -> 2 -> 3 -> 4 -> 6$
//   - $1 -> 3 -> 4 -> 6$
//   - $1 -> 4 -> 6 -> 5$
  
//   בהרצת BFS בהכרח נקבל ש-$2,3,4$ ילדים של

+ העץ הבא מכוון וחסר מעגלים:

  #diagram($
    & 1 edge(->, "dl") edge(->, "dr") \
    2 edge(->,"rr") && 3
  $)

  נאכל להריץ BFS ו-DFS מ-$1$ כאשר ברשימת השכנויות של $1$, $3$ מופיע לפני $2$ ואז בשני המקרים נקבל את העץ:

  #diagram($
    & 1 edge("dl",->) edge("dr",->) \
    2 && 3
  $)

  שהוא לא העץ המקורי.

  קיימת דוגמא נגדית ולכן הטענה לא נכונה.

+ בעץ בהכרח מתקיים $abs(E) = abs(V) - 1$ ולכן בהכרח ב-$G$ יש יותר קשתות מבכל עץ BFS או DFS שלו, ניקח עץ DFS כלשהו $T_0$, אז כאמור בהכרח יש קשת $(u,v)$ ב-$G$ שאין ב-$T_1$, נוכל להריץ BFS מ-$u$ ב-$G$ ואז בהכרח העץ המתקבל $T_2$ יכיל את הקשת $(u,v)$, אז $T_1 != T_2$. נוכל לסדר את רשימות השכנויות של $G$ כך שבכל צומת הקשתות שמופיעות ב-$T_1$ יופיעו קודם ברשימת השכנויות, אז כשנריץ DFS מכל קדקוד על הגרף נקבל שלכל שני קדקודים האלגוריתם עובר קודם במסלול היחודי שקיים ביניהם בעץ $T_1$ ולכן נוכל לקבל את $T_1$ עצמו ע"י הרצת DFS מ-$u$. אז הטענה נכונה.

#pagebreak()
#pagebreak()

+ ראשית אם יש מסלול המילטון אז קיים מיון טופולוגי ובו $u < v$ אמ"מ $u$ מופיע לפני $v$ במסלול.

  נניח בשלילה כי קיים מיון טופולוגי נוסף של הגרף ששונה מהמיון המתואר לעיל, אז קיימת קשת $(u,v)$ כך ש-$u$ לא מופיע לפני $v$ במסלול ההמילטון, אז קיים תת-מסלול של מסלול ההמילטון שהוא מסלול בין $v$ ל-$u$, וביחד עם הקשת הנתונה נקבל מעגל שעובר ב-$u$ ו-$v$, שזו סתירה לכך שהגרף חסר מעגלים. אז המיון הטופולוגי הוא יחיד.

+ בהנתן מיון טופולוגי יחודי $u_1,...,u_n$ נניח בשלילה כי קיים $i$ כך ש-$(u_i,u_(i+1)) in.not E$, אז נוכל להחליף את מיקומי $u_i$ ו-$u_(i+1)$ ולקבל מיון טופולוגי חדש שזו סתירה ליחודיות, לכן המיון הטופולוגי יוצר מסלול המילטון $u_1 -> u_2 -> .... -> u_n$.


+ נוכל להשתמש באלגוריתם מהתרגול למציאת מיון טופולוגי (שבהכרח קיים כי נתון ש-$G$ DAG) - $O(abs(V)+abs(E))$. כעט נבדוק אם יש קשת בין כל צומת לצומת שאחריה במיון הטופולוגי - $O(abs(V))$ - אם כן אז קיים מסלול המילטון ונחזיר true, אחרת כפי שהוכח בסעיף ב המיון הטופולוגי לא יחודי ולכן לפי סעיף א לא קיים מסלול המילטון אז נחזיר false.

#pagebreak()
#pagebreak()

// + *תנאי:* אחד מבין $u_0, ..., u_(k-1)$ אב קדמון של $u_k$.

//   אם התנאי מתקיים אז בהכרח יש מסלול בין $u_0$ ל-$u_k$ ב-$G'$ ולכן הם באותו רכיב קשירות.

//   אם $u_0, u_k$ באותו רכיב קשירות ב-$G'$, כלומר שקיים מסלול ביניהם ב-$G'$, אז בהכרח אחת הקשתות של המסלול תתגלה ב-DFS בזמן ש-$u_0$ עדיין אפור ולכן היא תהיה קשת אחורית.

+ *תנאי:* ל-$u_k$ יש אב קדמון בעל זמן גילוי קטן מזה של $u_k$

  אם התנאי מתקיים אז קיימת קשת מרכיב הקשירות של $u_k$ ב-$G'$ לרכיב קשירות של צומת גולת לפניה. מקיום המסלול הנתון ידוע כי $u_0$ פחות עמוקה וגולת לפני $u_k$ ו-$u_(k-1)$ ושהם באותו רכיב קשירות ב-$pi$ לכן אם נחתוך מ-$pi$ את $(u_(k-1), u_k)$, נקבל ש-$u_0$ יהיה באותו רכיב קשירות כמו כל הקדקודים שפחות עמוקים וגולו לפני $u_k$ ולכן יש קשת בין רכיב הקשירות של $u_k$ לזה של $u_0$ לכן הם באותו רכיב קשירות.

  אם $u_0$ ו-$u_k$ באותו רכיב קשירות ב-$G'$ אז בהכרח יש קשת מתת העץ של $pi$ ש-$k$ שורשו אל צומת מחוץ לו באותו עץ ב-$pi$ שאינו $u_(k-1)$ - אז הקודקוד הזה הוא אב קדמון ל-$u_k$, וכיוון ש-$G$ לא מכוון לקדקוד הזה בהכרח יש זמן גילוי קטן משל $u_k$.

+ בסעיף א מצאנו תנאי הכרחי ומספיק לכך שקשת ב-$pi$ היא לא גשר ב-$G$ (נסתכל על המסלול שמסתיים בקשת זו ומתחיל בשורש), נשים לב שגשר גם בהכרח מופיע ב-$pi$ כיוון שאחרת $pi$ יכיל יותר רכיבי קשירות מ-$G$ מה שאומר שהייתה טעות באלגוריתם. בנוסף נשים לב כי התנאי מהסעיף הקודם במקרה של מסלול שמתחיל בשורש שקול לכך ש-$"low"[u_k] < d[u_k]$. סה"כ קיבלנו שקשת ${u,v} in E$ היא גשר אמ"מ $(u,v) in pi$ וגם $"low"[v] >= d[v]$, או ש- $(v,u) in pi$ וגם $"low"[u] >= d[u]$, אז נוכל להריץ את אלגוריתם מציאת ה-low מהתרגול ב-$O(abs(E)+abs(V))$ ואז לעבור על כל הצמתים $v$ שאינם שורש ב-$pi$ ולבדוק $"low"[v] >= d[v]$ ב-$O(abs(V))$, סה"כ $O(abs(V)+abs(E))$.

+ נשים לב כי צומת הינה איבר במעגל אם"ם בהרצת DFS יש לה או לאחד מילדיה אב חורג שהוא גם אב קדמון שלה או היא עצמה, הדבר שקול לכך שיש לאחד מצאצאי הצומת אב חורג שזמן הגילוי שלו קטן או שווה לזה של הצומת עצמה, וזה שקול לכך שערך ה-low של הצומת קטן או שווה מזמן הגילוי שלה, לכן נוכל להריץ את אלגוריתם ה-low מהתרגול ואז פשוט לעבור על כל הצמתים $v$ ולבדוק עבור אילו $"low"[v] <= d[v]$ ובדומה לסעיף הקודם זה יצא $O(abs(V) + abs(E))$ סה"כ.

#pagebreak()
#pagebreak()

נריץ DFS על הגרף ונקבל עץ קשיר $pi$ בעל $abs(V)-1$ קשתות ובו כל קשת היא גשר כיוון שיש מסלול יחיד בין כל שני קדקודים. כפי שהוסבר בשאלה הקודמת לכל קשת $(u,v)$ ב-$pi$, הקשת לא גשר רק כאשר קיים ל-$v$ צאצא $s$ בעל אב חורג $w$ כך ש-$d[w] < d[v]$, ואז אם נוסיף את $(s,w) in E$ אל $pi$ נקבל ש-$(u,v)$ כבר לא גשר בו, אם נעשה זאת עבור כל הקשתות ב-$pi$ נקבל תת גרף של $G$ שבו כל הקשתות אינן גשרים ושמכיל לכל היותר $abs(V)-1$ יותר קשתות - סה"כ $2abs(V)-2$ קשתות לכל היותר.


#pagebreak()
#pagebreak()

נהפוך את כיוון קשתות הגרף בכדי שכעט נרצה למצוא $U$ בגודל $k$ כך שלכל קדקוד ב-$V\\U$ כך שיש מסלול מקדקוד כלשהו ב-$U$ אליו וגם שאין בתוכה מסלולים, כלומר נרצה למצוא קבוצת מוצא מינמלית של $V$ בגודל $k$. בתרגול ראינו אלגוריתם למציאת קבוצת מוצא מינמלית וכחלק ממנו הוכח שכל קבוצות כאלו בעלי אותו גודל לכן נוכל פשוט להריץ את האלגוריתם ובמקרה בו קיבלנו קבוצה בת $k$ איברים להחזיר אותה ואחרת להצהיר שלא קיימת קבוצה הממצה את הדרישות, סה"כ $O(abs(E) + abs(V))$.


#pagebreak()
#pagebreak()

ניצור גרף עם צמתים $1, ..., n$ ובו יש קשת בין $i$ ל-$j$ אם"ם נתון אי השוויון $X_i <= X_j$ - $O(n+m)$. נאכל להריץ DFS - $O(n+m)$ - בכדי ליצור את גרף הרק"חים, נשים לב כי שני צמתים הם באותו רק"ח אמ"מ קיים מעגל העובר בשניהם כלומר ש-$i,j$ באותו רק"ח אמ"מ נתונות המשוואות:

$
  X_i_0 <= X_i_1, space X_i_1 <= X_i_2, space ..., space X_i_(n-1) <= X_i_n
$

כאשר $i_0 = i$ ו-$i_n = j$, והדרך היחידה לרצות משוואות אלו היא כאשר $X_i = X_j$ ולכן לווקטור מקסימלי לא יהיה פיזור שגדול ממספר הרק"חים.

גרף הרק"חים הוא DAG בהכרח לכן נוכל להריץ את אלגוריתם מיון טופולוגי מהתרגול - $O(n+m)$ - ואז להגדיר $X$ כך שערך $X_i$ יהיה מיקום רכיב הקשירות של $i$ במיון, הוקטור ירצה את דרישות הסדר עקב תכונות המיון הטופולוגי והעובדה שאיברים באותו רק"ח שווים ולכן סדרם לא משנה, אך הוא גם יהיה בעל פיזור ששווה למספר הרקח"ים ולכן מקסימלי. סה"כ $O(m + n)$.


#pagebreak()
#pagebreak()

+ נריץ DFS החל מכל קדקוד ואם עבור אחד מהם קיבלנו גרף שחור לגמרי לאחר הקדקוד האחד אז התכונה נכונה, אחרת לא - $O(abs(V)^2 + abs(V)abs(E))$.

+ נהפוך את כיוון כל הקשתות בגרף, כעט נרצה שלכל $u,v$ קיים $w$ כך שיש מסלולים $u arrow.wave.l w arrow.wave v$, נשים לב כי הדבר שקול לכך שיש $w$ יחיד שיוצאים ממנו מסלולים לכל שאר הקדקודים - כיוון אחד נובע ישירות, ומכיוון שני אם לכל $u_1,u_2,v_1,_v_2$ קיימים $w_1,w_2$ כך שיש מסלולים $v_1 arrow.wave.l w_1 arrow.wave.r u_1$ ו-$v_1 arrow.wave.l w_1 arrow.wave.r u_1$, אבל קיים גם $w_0$ כך שקיימים מסלולים $w_1 arrow.wave.l w_0 arrow.wave w_2$ ולכן קיימים מסלולים $u_1,u_2,v_1,v_2 arrow.wave.l w_0$, ונוכל לחזור על התהליך עם זוגות קדקודים עד שעברנו על כל הקדקודים ($ceil(abs(V)/2)$ זוגות במינימום) ולהשיג $w$ המקיים את הדרוש - לכן נוכל כעט להריץ את האלגוריתם מהסעיף הקודם ולקבל תשובה ב-$O(abs(V)^2 + abs(V)abs(E))$.


#pagebreak()